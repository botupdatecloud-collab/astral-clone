<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AstralClone" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_accent</item>
        <item name="colorPrimaryVariant">#4a3fcc</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.AstralClone.Splash" parent="Theme.AstralClone">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Update dialog style -->
    <style name="UpdateDialogStyle" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorSurface">#0d0d35</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorPrimary">@color/purple_accent</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>

</resources>
