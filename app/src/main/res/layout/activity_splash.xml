<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:gravity="center">

    <!-- Glow circle behind logo -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true"
        android:background="@drawable/glow_circle" />

    <!-- Logo icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="𝔸"
        android:textSize="72sp"
        android:textColor="@color/purple_accent"
        android:fontFamily="sans-serif-black" />

    <!-- App name -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/android:empty"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="260dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ASTRAL CLONE"
            android:textSize="26sp"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.15" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Multi Space by Team Astral Core"
            android:textSize="12sp"
            android:textColor="@color/text_dim"
            android:letterSpacing="0.08"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvSplashVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.0"
            android:textSize="11sp"
            android:textColor="@color/purple_accent"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Bottom loader dots -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="48dp"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦  ✦  ✦"
            android:textSize="14sp"
            android:textColor="@color/purple_accent"
            android:alpha="0.6" />
    </LinearLayout>

</RelativeLayout>
