<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ═══ HEADER ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp">

            <!-- Logo box -->
            <androidx.cardview.widget.CardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#1a0a4a"
                app:cardElevation="8dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="𝔸"
                    android:textSize="26sp"
                    android:textColor="@color/purple_accent"
                    android:gravity="center"
                    android:fontFamily="sans-serif-black" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ASTRAL CLONE"
                    android:textSize="18sp"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1" />
                <TextView
                    android:id="@+id/tvVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.0.0"
                    android:textSize="11sp"
                    android:textColor="@color/purple_accent" />
            </LinearLayout>

            <!-- Settings icon -->
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="⚙"
                android:textSize="22sp"
                android:textColor="@color/text_dim"
                android:gravity="center" />
        </LinearLayout>

        <!-- ═══ ACTIVE SPACE BANNER ═══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#1a1040"
            app:cardElevation="12dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVE SPACE"
                    android:textSize="10sp"
                    android:textColor="@color/text_dim"
                    android:letterSpacing="0.2" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌌  Space Alpha"
                        android:textSize="22sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/badge_active"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 apps cloned"
                    android:textSize="12sp"
                    android:textColor="@color/text_dim"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ SPACES LABEL ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Spaces"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="12dp" />

        <!-- ═══ SPACES ROW ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- Space Alpha -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSpace1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#1e1060"
                app:cardElevation="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌌" android:textSize="28sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Alpha" android:textSize="12sp" android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2 apps" android:textSize="10sp" android:textColor="@color/text_dim" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Space Beta -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSpace2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#0a1a30"
                app:cardElevation="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌠" android:textSize="28sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Beta" android:textSize="12sp" android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2 apps" android:textSize="10sp" android:textColor="@color/text_dim" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Space Gamma -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSpace3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#1a0a20"
                app:cardElevation="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✨" android:textSize="28sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Gamma" android:textSize="12sp" android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 apps" android:textSize="10sp" android:textColor="@color/text_dim" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ═══ CONTACT LABEL ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Us"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="12dp" />

        <!-- ═══ WHATSAPP ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnWhatsApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#0d2015"
            app:cardElevation="8dp"
            android:layout_marginBottom="12dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:text="💬" android:textSize="26sp" android:gravity="center"
                    android:background="@drawable/icon_bg_green" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="WhatsApp Channel" android:textSize="15sp"
                        android:textColor="@color/white" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Astral Core Official" android:textSize="12sp"
                        android:textColor="#25D366" android:layout_marginTop="2dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Updates &amp; announcements" android:textSize="11sp"
                        android:textColor="@color/text_dim" android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="→" android:textSize="18sp" android:textColor="#25D366" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ TELEGRAM ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnTelegram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#0a1a2a"
            app:cardElevation="8dp"
            android:layout_marginBottom="12dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:text="✈️" android:textSize="26sp" android:gravity="center"
                    android:background="@drawable/icon_bg_blue" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Telegram" android:textSize="15sp"
                        android:textColor="@color/white" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@nmd_coder" android:textSize="12sp"
                        android:textColor="#2AABEE" android:layout_marginTop="2dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Direct support &amp; inquiries" android:textSize="11sp"
                        android:textColor="@color/text_dim" android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="→" android:textSize="18sp" android:textColor="#2AABEE" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ YOUTUBE ═══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnYouTube"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#200a0a"
            app:cardElevation="8dp"
            android:layout_marginBottom="24dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <TextView android:layout_width="48dp" android:layout_height="48dp"
                    android:text="▶️" android:textSize="26sp" android:gravity="center"
                    android:background="@drawable/icon_bg_red" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="YouTube" android:textSize="15sp"
                        android:textColor="@color/white" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@team_astral_yt" android:textSize="12sp"
                        android:textColor="#FF4444" android:layout_marginTop="2dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tutorials &amp; demos" android:textSize="11sp"
                        android:textColor="@color/text_dim" android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="→" android:textSize="18sp" android:textColor="#FF4444" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✦  Made with ♥ in Sri Lanka  ✦"
            android:textSize="11sp"
            android:textColor="@color/text_dim"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:alpha="0.6" />

    </LinearLayout>
</ScrollView>
